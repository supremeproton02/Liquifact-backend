{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus data source for LiquiFact metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "9.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "5.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "bargauge",
      "name": "Bar gauge",
      "version": ""
    }
  ],
  "id": null,
  "title": "LiquiFact — DoS Detection: Body-Size Limit Rejections",
  "description": "Dashboards for monitoring body-size limit rejection rates (413 Payload Too Large) broken down by parser type. Alerts on rapid increases indicate potential DoS attacks.",
  "tags": ["liquifact", "dos-detection", "security"],
  "timezone": "browser",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": [
      "5s",
      "10s",
      "30s",
      "1m",
      "5m",
      "15m",
      "30m",
      "1h",
      "2h",
      "1d"
    ],
    "time_options": [
      "5m",
      "15m",
      "1h",
      "6h",
      "12h",
      "24h",
      "2d",
      "7d",
      "30d"
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Rejection Rate by Type",
      "description": "Rate of body-size limit rejections per second, broken down by parser type (json, urlencoded, invoice, unknown). A rate > 0.167 (10/min) sustained for 2m triggers the warning alert.",
      "type": "timeseries",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max", "lastNotNull"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.167
              },
              {
                "color": "red",
                "value": 0.5
              }
            ]
          },
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineInterpolation": "smooth",
            "showPoints": "never",
            "fillOpacity": 20,
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(body_size_limit_rejections_total{type=\"json\"}[5m])",
          "legendFormat": "json",
          "refId": "A"
        },
        {
          "expr": "rate(body_size_limit_rejections_total{type=\"urlencoded\"}[5m])",
          "legendFormat": "urlencoded",
          "refId": "B"
        },
        {
          "expr": "rate(body_size_limit_rejections_total{type=\"invoice\"}[5m])",
          "legendFormat": "invoice",
          "refId": "C"
        },
        {
          "expr": "rate(body_size_limit_rejections_total{type=\"unknown\"}[5m])",
          "legendFormat": "unknown",
          "refId": "D"
        },
        {
          "expr": "sum(rate(body_size_limit_rejections_total[5m]))",
          "legendFormat": "total (all types)",
          "refId": "E"
        }
      ],
      "thresholds": [
        {
          "value": 0.167,
          "color": "yellow",
          "label": "Warning threshold (10/min)"
        },
        {
          "value": 0.5,
          "color": "red",
          "label": "Critical threshold (30/min)"
        }
      ]
    },
    {
      "id": 2,
      "title": "Current Rejection Rate",
      "description": "Current per-second rate of body-size rejections across all types. Green = normal, Yellow = warning zone, Red = critical (active DoS).",
      "type": "stat",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"]
        },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.167
              },
              {
                "color": "red",
                "value": 0.5
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(body_size_limit_rejections_total[5m]))",
          "legendFormat": "Total rejection rate",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Rejections by Type (Current)",
      "description": "Current per-type rejection rates. Each bar shows the rate for one parser type. Type 'unknown' is especially suspicious — it indicates requests with unrecognized or missing Content-Type headers.",
      "type": "bargauge",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.167
              },
              {
                "color": "red",
                "value": 0.5
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(body_size_limit_rejections_total{type=\"json\"}[5m])) by (type)",
          "legendFormat": "{{ type }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Cumulative Rejections (Last Hour)",
      "description": "Total number of body-size rejections in the last hour, broken down by type. A value exceeding 600 (~10/min) sustained suggests misconfiguration or sustained probing.",
      "type": "bargauge",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 10
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 100
              },
              {
                "color": "red",
                "value": 600
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(increase(body_size_limit_rejections_total[1h])) by (type)",
          "legendFormat": "{{ type }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Cumulative Rejections Over Time",
      "description": "Running total of body-size rejections in the last hour, showing how the cumulative count grows over the selected time window.",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 10
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max", "lastNotNull"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 100
              },
              {
                "color": "red",
                "value": 600
              }
            ]
          },
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineInterpolation": "smooth",
            "showPoints": "never",
            "fillOpacity": 20,
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "increase(body_size_limit_rejections_total{type=\"json\"}[1h])",
          "legendFormat": "json",
          "refId": "A"
        },
        {
          "expr": "increase(body_size_limit_rejections_total{type=\"urlencoded\"}[1h])",
          "legendFormat": "urlencoded",
          "refId": "B"
        },
        {
          "expr": "increase(body_size_limit_rejections_total{type=\"invoice\"}[1h])",
          "legendFormat": "invoice",
          "refId": "C"
        },
        {
          "expr": "increase(body_size_limit_rejections_total{type=\"unknown\"}[1h])",
          "legendFormat": "unknown",
          "refId": "D"
        }
      ]
    },
    {
      "id": 6,
      "title": "Alert Threshold Reference",
      "description": "Key alert thresholds for the DoS detection rules defined in docs/prometheus-rules.yml.",
      "type": "bargauge",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 10
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "options": {
        "orientation": "vertical",
        "displayMode": "basic",
        "showUnfilled": true,
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.167
              },
              {
                "color": "red",
                "value": 0.5
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "displayMode": "basic"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(body_size_limit_rejections_total[5m]))",
          "legendFormat": "Current rate",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Historical Rejection Heatmap",
      "description": "Heatmap showing body-size rejection events over time. Each cell represents the number of rejections in a 5-minute bucket. Helps identify attack patterns (sustained, burst, or distributed).",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 18
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "rgba(50, 172, 45, 0.97)",
                "value": null
              },
              {
                "color": "rgba(237, 129, 40, 0.89)",
                "value": 0.167
              },
              {
                "color": "rgba(245, 54, 54, 0.9)",
                "value": 0.5
              }
            ]
          },
          "custom": {
            "lineInterpolation": "stepAfter",
            "showPoints": "always",
            "fillOpacity": 70,
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(body_size_limit_rejections_total[5m]))",
          "legendFormat": "All types",
          "refId": "A"
        }
      ]
    }
  ]
}
